# Copy to .env.local (install.sh does this for you) and fill in.

# The Movie Database API key — powers posters, streaming info, and details.
# Free key: https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Absolute path to your movie wiki folder (the app reads/writes it).
# install.sh sets this; a fresh wiki is scaffolded from vault-template/ if empty.
VAULT_PATH=

# Optional — for the in-app chat expert (Claude Agent SDK).
# Leave blank to use a logged-in Claude Code CLI instead.
# Key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
