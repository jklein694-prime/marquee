# models.catalog — the runtime menu of GGUF models the dashboard/CLI can
# download and switch to. One [entry] block per model; parsed by models.py.
#
# ram_tier is the MINIMUM board this model is safe on: a "1.5b" model is
# refused on a 2GB Nano (detected tier 0.5b) unless you pass --force. Keep the
# two shipped models in sync with PINS.env (PINS is the build-time source of
# truth; this file is the on-device menu). You can also download any raw
# Hugging Face .gguf URL with `gardener models download <url>` without editing
# this file.

[qwen2.5-1.5b]
name = Qwen2.5 1.5B Instruct (Q4_K_M)
file = qwen2.5-1.5b-instruct-q4_k_m.gguf
url = https://huggingface.co/Qwen/Qwen2.5-1.5B-Instruct-GGUF/resolve/main/qwen2.5-1.5b-instruct-q4_k_m.gguf
sha256 = TBD
ram_tier = 1.5b
ctx = 3072

