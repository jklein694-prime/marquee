# PINS.env — single source of truth for every artifact baked into the USB payload.
#
# Why these exact versions (do not bump casually):
#
#   LLAMACPP_TAG=b2275 (2024-02-26). The Jetson Nano is frozen at JetPack 4.6 =
#   Ubuntu 18.04 / GCC 7 / CMake 3.10 / CUDA 10.2. The tag must be:
#     - new enough for GGUF, the qwen2 architecture (~b1610) and the built-in
#       HTTP server with /completion + /v1/chat/completions (~b1592)
#     - old enough to still compile under GCC 7 (the C++17/newer-CMake
#       requirements arrived with the mid-2024 ggml refactor) and to keep a
#       CUDA backend (LLAMA_CUBLAS) that accepts CUDA 10.2 / sm_53
#   If ci/gcc7-build-check.sh goes red on this tag, walk back toward b1971 or
#   b1808 and update LLAMACPP_TAG here — nothing else references the tag.
#
#   Models: Qwen2.5-Instruct, NOT Qwen3 — Qwen3 needs a 2025-era llama.cpp
#   that will not build on the Nano's toolchain. Both tiers ship on the USB;
#   the installer picks by detected RAM (4GB board -> 1.5b, 2GB board -> 0.5b).
#
# SHA256 policy (trust-on-first-use): this repo's authoring environment cannot
# reach huggingface.co / github.com, so hashes start as TBD. The FIRST run of
# build-payload.sh on your online machine downloads each artifact, computes its
# sha256, and rewrites the TBD entries here (print + git-diffable). Every later
# build verifies against the recorded hash and fails hard on mismatch. Commit
# the filled-in file after the first successful build.

LLAMACPP_TAG="b2275"
LLAMACPP_URL="https://github.com/ggerganov/llama.cpp/archive/refs/tags/${LLAMACPP_TAG}.tar.gz"
LLAMACPP_SHA256="TBD"

# 4GB-RAM tier ("1.5b")
MODEL_1_5B_REPO="Qwen/Qwen2.5-1.5B-Instruct-GGUF"
MODEL_1_5B_FILE="qwen2.5-1.5b-instruct-q4_k_m.gguf"
MODEL_1_5B_URL="https://huggingface.co/${MODEL_1_5B_REPO}/resolve/main/${MODEL_1_5B_FILE}"
MODEL_1_5B_SHA256="TBD"

# 2GB-RAM tier ("0.5b")
MODEL_0_5B_REPO="Qwen/Qwen2.5-0.5B-Instruct-GGUF"
MODEL_0_5B_FILE="qwen2.5-0.5b-instruct-q4_k_m.gguf"
MODEL_0_5B_URL="https://huggingface.co/${MODEL_0_5B_REPO}/resolve/main/${MODEL_0_5B_FILE}"
MODEL_0_5B_SHA256="TBD"
