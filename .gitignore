# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# personal / machine-specific Claude Code state (permissions, loop state, etc.)
.claude/settings.local.json
.claude/*.local.*

# dev/scratch artifacts (screenshots at repo root, playwright captures)
/*.png
/*.jpg
/*.jpeg
/.playwright-mcp/
/full-page.yml

# typescript
*.tsbuildinfo
next-env.d.ts

# transient wiki-lint handoff, consumed each chat turn
data/lint-pending.txt
.claude/launch.json
data/snoozed.json
data/watchlist.json
.claude/launch.json
